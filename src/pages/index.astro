---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CalculatorApp from '../components/CalculatorApp';
import FaqAccordion from '../components/FaqAccordion';
import styles from '../styles/HomePage.module.css';

const pageTitle = 'Age Calculator by Date of Birth - Free Online Tool | Age Calculator Pro';
const pageDescription =
	'Calculate your exact age in years, months, weeks, days, hours, and minutes from your date of birth. A free, private, browser-based age calculator with age-difference and life-statistics tools.';
const pageKeywords =
	'age calculator, date of birth calculator, age calculator by date of birth, age in years months days, age difference calculator, days between dates';
const canonical = 'https://agecalculatorpro.app/';

const faqItems = [
	{
		question: 'How does the age calculator work?',
		answer:
			'The calculator takes your date of birth and a target date (today by default) and computes the exact calendar difference in years, months, and days. From that exact day count it derives total weeks, hours, and minutes. All math runs in your browser.',
	},
	{
		question: 'Can I calculate my age at a future date?',
		answer:
			'No. The tool blocks future date inputs so that results are grounded in actual elapsed time. If you need to plan around a future event, subtract from your current age or use the age-difference tab with two known past dates.',
	},
	{
		question: 'Is my date of birth stored or shared?',
		answer:
			'No. Age calculations run entirely on your device. Your date of birth is never sent to a server or saved to a database. You do not need an account to use any feature.',
	},
	{
		question: 'What does the age difference tool do?',
		answer:
			'It compares two dates of birth and returns the absolute gap in years, months, and days. It is useful for couples, siblings, classmates, sports-eligibility checks, and HR onboarding.',
	},
	{
		question: 'Does the tool handle leap years correctly?',
		answer:
			'Yes. The engine uses real calendar arithmetic, so February 29 births, leap-year spans, and month-length variation are all handled without approximation.',
	},
	{
		question: 'Do I need to install anything or sign up?',
		answer:
			'No. Age Calculator Pro is a free web app. Open the page, enter your date of birth, and get results instantly. It works on mobile, tablet, and desktop browsers.',
	},
];

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: 'Age Calculator Pro',
		url: canonical,
		logo: `${canonical}favicon.svg`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'Age Calculator Pro',
		applicationCategory: 'UtilitiesApplication',
		operatingSystem: 'Any',
		url: canonical,
		description: pageDescription,
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: canonical,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Calculator',
				item: `${canonical}#calculator`,
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: 'FAQ',
				item: `${canonical}#faq`,
			},
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'How to calculate age by date of birth',
		description:
			'Use Age Calculator Pro to calculate your exact age from your date of birth in years, months, weeks, days, hours, and minutes.',
		totalTime: 'PT1M',
		step: [
			{
				'@type': 'HowToStep',
				name: 'Open the age calculator',
				text: 'Open Age Calculator Pro in your browser. No registration is required.',
				url: `${canonical}#calculator`,
			},
			{
				'@type': 'HowToStep',
				name: 'Enter your date of birth',
				text: 'Select your date of birth in the Date Of Birth field. Future dates are not allowed.',
			},
			{
				'@type': 'HowToStep',
				name: 'Choose the calculate-at date',
				text: 'Keep today as the default or pick a custom past date to compute age as of that point.',
			},
			{
				'@type': 'HowToStep',
				name: 'Click Calculate Age',
				text: 'Press Calculate Age to view an exact breakdown in years, months, weeks, days, hours, and minutes.',
			},
		],
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	keywords={pageKeywords}
	canonical={canonical}
	schemas={schemas}
>
	<Header />

	<main id="home">
		<section class={styles.hero}>
			<div class="container">
				<div class={styles.heroContent}>
					<h1>
						<span class={styles.gradientText}>Age Calculator</span> - Calculate Your Exact Age by Date of Birth
					</h1>
					<p>
						A free, fast, and privacy-first age calculator. Enter your date of birth to see your exact age in years,
						months, weeks, days, hours, and minutes. All calculations run in your browser - nothing is uploaded or stored.
					</p>
					<p class={styles.reviewMeta}>
						Reviewed by the Age Calculator Pro editorial team &middot; Last updated June 23, 2026
					</p>
				</div>
			</div>
		</section>

		<section id="calculator" class={`section ${styles.calculatorSection}`}>
			<div class="container">
				<div class={styles.sectionHead}>
					<h2>Precision Age Engine</h2>
					<p>Run exact age and age-difference calculations, then share or export the result.</p>
				</div>
				<CalculatorApp client:load />
			</div>
		</section>

		<section class="section" id="about">
			<div class="container">
				<div class={styles.sectionHead}>
					<h2>Life Statistics You Actually Understand</h2>
					<p>Beyond raw numbers, the tool surfaces context that turns dates into insight.</p>
				</div>
				<div class={styles.featureGrid}>
					<article class={`card ${styles.featureCard}`}>
						<h3>Milestone Tracking</h3>
						<p>See exactly how many days remain until your next birthday and important age milestones such as 18, 21, 40, 60, and 65.</p>
					</article>
					<article class={`card ${styles.featureCard}`}>
						<h3>Human-readable Totals</h3>
						<p>Instead of just a year count, get compact totals for weeks lived, hours lived, and minutes lived - useful for planning and reflection.</p>
					</article>
					<article class={`card ${styles.featureCard}`}>
						<h3>Estimated Biometrics</h3>
						<p>Rough heartbeat and sleep-hour estimates based on typical human averages, presented as ballpark figures rather than medical values.</p>
					</article>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class={styles.sectionHead}>
					<h2>Why We Built Age Calculator Pro</h2>
					<p>Most age calculators are ad-heavy, inaccurate around month-ends, or ask for accounts. This one is different.</p>
				</div>
				<div class={styles.featureGrid}>
					<article class={`card ${styles.featureCard}`}><h3>Fast Results</h3><p>Client-side math means results appear the instant you click Calculate. No page reloads, no waiting on a server.</p></article>
					<article class={`card ${styles.featureCard}`}><h3>Calendar-accurate</h3><p>Real Gregorian calendar arithmetic, so leap years, month lengths, and short-February edge cases behave correctly.</p></article>
					<article class={`card ${styles.featureCard}`}><h3>Mobile First</h3><p>The layout is designed for phones first, with touch-friendly date pickers and readable result cards.</p></article>
					<article class={`card ${styles.featureCard}`}><h3>No Registration</h3><p>Every feature - calculation, sharing, PDF and PNG export - works without creating an account or verifying an email.</p></article>
					<article class={`card ${styles.featureCard}`}><h3>Always Free</h3><p>The full toolset is free. There is no premium tier gating basic features and no paywall on results.</p></article>
					<article class={`card ${styles.featureCard}`}><h3>Deep Analysis</h3><p>Age, age-difference, life statistics, and exportable reports live together in one clean workflow.</p></article>
				</div>
			</div>
		</section>

		<section id="how" class="section">
			<div class="container">
				<div class={styles.sectionHead}>
					<h2>How to Use the Calculator (Step by Step)</h2>
					<p>Four short steps from a birthday to a full age breakdown.</p>
				</div>
				<div class={styles.stepsGrid}>
					<article class={`card ${styles.stepCard}`}>
						<span class={styles.stepBadge}>1</span>
						<h3>Open the tool</h3>
						<p>You are already here - scroll up to the Precision Age Engine section. Nothing to install.</p>
					</article>
					<article class={`card ${styles.stepCard}`}>
						<span class={styles.stepBadge}>2</span>
						<h3>Enter your date of birth</h3>
						<p>Use the Date Of Birth field. The picker respects your device locale, and future dates are automatically blocked.</p>
					</article>
					<article class={`card ${styles.stepCard}`}>
						<span class={styles.stepBadge}>3</span>
						<h3>Pick the calculate-at date</h3>
						<p>Leave it on today for your current age, or pick a past date to see how old you were on that specific day.</p>
					</article>
					<article class={`card ${styles.stepCard}`}>
						<span class={styles.stepBadge}>4</span>
						<h3>Read, share, or export</h3>
						<p>Click Calculate Age. Use Share to copy a summary, or export the result card as a PDF or PNG file.</p>
					</article>
				</div>
			</div>
		</section>

		<section id="faq" class="section">
			<div class="container">
				<div class={styles.sectionHead}>
					<h2>Frequently Asked Questions</h2>
					<p>Everything you need to know before running your first calculation.</p>
				</div>
				<FaqAccordion client:load />
			</div>
		</section>

		<section id="about-tool" class="section">
			<div class="container">
				<article class={`card ${styles.seoContent}`}>
					<h2>About the Age Calculator - Calculate Your Age by Date of Birth Online</h2>
					<p>
						The <strong>Age Calculator</strong> from Age Calculator Pro is a free, browser-based
						<strong> date of birth calculator</strong> that returns your exact age in seconds. Whether you need a quick
						answer for a school-admission form, a passport application, an insurance renewal, a retirement plan, or
						simple personal curiosity, this tool gives you a precise breakdown in years, months, weeks, days, hours,
						and minutes with no advertisements or interruptions inside the calculator flow itself.
					</p>

					<h3>How the Age Calculator Formula Works</h3>
					<p>
						Our engine uses real calendar arithmetic rather than a naive division by 365.25. First it finds the calendar
						difference in years, months, and days between your date of birth and the chosen calculate-at date. From that
						exact day span it derives total weeks, total hours, and total minutes. Because leap years and month lengths
						are handled explicitly, month-end and February 29 births produce results that match the intuitive answer a
						government office or human reviewer would give.
					</p>

					<h3>What You Can Do With the Results</h3>
					<p>
						The output card is deliberately structured so you can either read it at a glance or use it as documentation.
						You can copy a short summary line to paste into a chat or email, export the full result as a PDF file to
						attach to an application, or save a PNG image for social sharing. Because everything is generated locally,
						exports contain only the data you entered - there are no hidden tracking pixels or third-party watermarks
						embedded in the file.
					</p>

					<h3>Common Uses for an Online Age Calculator</h3>
					<p>
						Beyond simple curiosity, people use an <strong>age calculator by date of birth</strong> for practical
						reasons. Common scenarios include verifying eligibility for competitive exams and government schemes,
						calculating age at a specific past date (such as the deadline for a scholarship application), checking
						minimum-age requirements for driving licenses, visas, and voter registration, and preparing accurate
						age fields on medical, HR, and legal forms. The tool also doubles as a lightweight
						<strong> days calculator</strong>: enter any two past dates in the age-difference tab and read the exact
						number of years, months, and days between them.
					</p>

					<h3>Accuracy, Time Zones, and Edge Cases</h3>
					<p>
						All date inputs are normalized to your local calendar boundaries. That means a birthday selected in your
						picker is treated as a full day rather than a moment in time, which avoids the classic bug where a person
						born just before midnight appears to be a day younger on servers in a different time zone. Leap-day births,
						month lengths, and multi-decade spans all produce calendar-correct results.
					</p>

					<h3>Privacy and Data Handling</h3>
					<p>
						Age Calculator Pro was built with a privacy-by-default posture. The core calculation runs entirely on your
						device using the browser's own date engine. Your date of birth is never transmitted to our servers, saved
						to a database, or shared with third parties. We do not require sign-up, and we do not use the date you enter
						for advertising personalization. For full details, see our
						<a href="/privacy-policy">Privacy Policy</a> and <a href="/cookie-policy">Cookie Policy</a>.
					</p>

					<h3>Want to Learn More?</h3>
					<p>
						Browse our <a href="/guides">guides section</a> for original in-depth articles on chronological vs biological
						age, leap-year edge cases, how to calculate age for official documents, and understanding zodiac signs
						by birth date. Each guide is written by our editorial team and reviewed before publication.
					</p>
				</article>
			</div>
		</section>

	</main>

	<Footer />
</BaseLayout>
