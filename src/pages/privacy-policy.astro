---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import styles from '../styles/PolicyPage.module.css';

const pageTitle = 'Privacy Policy - Age Calculator Pro | Private & Secure Age Calculator';
const pageDescription =
  'Read how Age Calculator Pro handles data on our free age calculator by date of birth. Client-side calculations, no account required, GDPR-friendly approach.';
const pageKeywords = 'privacy policy, data privacy, cookies, gdpr, ccpa';
const canonical = 'https://agecalculatorpro.app/privacy-policy';

const sections = [
  { id: 'overview', title: '1. Overview' },
  { id: 'information-we-collect', title: '2. Information We Collect' },
  { id: 'how-we-use-information', title: '3. How We Use Information' },
  { id: 'legal-bases', title: '4. Legal Bases (Where Applicable)' },
  { id: 'cookies-analytics', title: '5. Cookies and Analytics' },
  { id: 'advertising', title: '6. Advertising and Third-Party Vendors' },
  { id: 'data-retention', title: '7. Data Retention' },
  { id: 'data-sharing', title: '8. Data Sharing and Processors' },
  { id: 'security', title: '9. Security' },
  { id: 'your-rights', title: '10. Your Privacy Rights' },
  { id: 'us-privacy', title: '11. US State Privacy Rights' },
  { id: 'children', title: '12. Children\'s Privacy' },
  { id: 'international-transfers', title: '13. International Transfers' },
  { id: 'changes', title: '14. Changes to This Policy' },
  { id: 'contact', title: '15. Contact Us' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: canonical,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonical={canonical}
  schemas={[schema]}
>
  <Header />

  <main>
    <section class={styles.hero}>
      <div class="container">
        <h1>Privacy Policy</h1>
        <p>
          This Privacy Policy explains how Age Calculator Pro handles information when you use our website,
          calculators, sharing tools, and export features.
        </p>
        <div class={styles.metaRow}>
          <span class={styles.badge}>Effective date: June 23, 2026</span>
          <span class={styles.badge}>Last reviewed: June 23, 2026</span>
        </div>
      </div>
    </section>

    <section>
      <div class={`container ${styles.contentWrap}`}>
        <aside class={`card ${styles.sideNav}`} aria-label="Policy section navigation">
          <h2>Contents</h2>
          <ul>
            {sections.map((section) => (
              <li><a href={`#${section.id}`}>{section.title}</a></li>
            ))}
          </ul>
        </aside>

        <article class={`card ${styles.mainContent}`}>
          <section id="overview">
            <h2>1. Overview</h2>
            <p>
              Age Calculator Pro is a free web application that helps users calculate age-related results and
              generate shareable exports. We are committed to transparency, minimal data processing, and privacy-by-design.
            </p>
            <p class={styles.callout}>
              Core calculator inputs are processed in your browser. We do not require account creation to use core features.
            </p>
          </section>

          <section id="information-we-collect">
            <h2>2. Information We Collect</h2>
            <p>We may process the following categories of information:</p>
            <ul>
              <li>Input data you provide in forms (such as date values used for age calculations).</li>
              <li>Technical data such as browser type, device information, and general usage diagnostics.</li>
              <li>Basic analytics and performance telemetry, if enabled in hosting or analytics platforms.</li>
              <li>Contact details you voluntarily provide if you email us for support.</li>
            </ul>
          </section>

          <section id="how-we-use-information">
            <h2>3. How We Use Information</h2>
            <ul>
              <li>To provide and operate calculator features, sharing tools, and export functionality.</li>
              <li>To maintain reliability, monitor performance, and improve user experience.</li>
              <li>To respond to support requests and resolve technical issues.</li>
              <li>To prevent abuse, fraud, or misuse of the service.</li>
            </ul>
          </section>

          <section id="legal-bases">
            <h2>4. Legal Bases (Where Applicable)</h2>
            <p>Where privacy laws such as GDPR apply, our processing may rely on:</p>
            <ul>
              <li>Legitimate interests in providing and securing the service.</li>
              <li>Consent for optional analytics or cookie-based features.</li>
              <li>Compliance with legal obligations.</li>
            </ul>
          </section>

          <section id="cookies-analytics">
            <h2>5. Cookies and Analytics</h2>
            <p>
              We may use essential storage mechanisms (for example, local browser storage for theme preferences)
              and limited analytics tools to understand service quality.
            </p>
            <ul>
              <li>Essential storage: supports core UI preferences and functionality.</li>
              <li>Analytics storage: helps us understand aggregate traffic and performance trends.</li>
              <li>You can manage storage and cookie behavior through your browser settings.</li>
            </ul>
            <p>
              For a full list of cookie categories and how to control them, see our
              <a href="/cookie-policy">Cookie Policy</a>.
            </p>
          </section>

          <section id="advertising">
            <h2>6. Advertising and Third-Party Vendors</h2>
            <p>
              To keep Age Calculator Pro free to use, we may display advertisements served by third-party ad networks, including
              Google AdSense and its approved partners. These third parties may use cookies, web beacons, and similar technologies
              to serve, measure, and improve ads based on your visit to this site and other sites you have visited.
            </p>
            <ul>
              <li>
                Google, as a third-party vendor, uses cookies to serve ads on our site. Google's use of the
                DoubleClick DART cookie enables it and its partners to serve ads to users based on their visit to our site
                and other sites on the Internet.
              </li>
              <li>
                You can opt out of personalized advertising by Google by visiting
                <a href="https://www.google.com/settings/ads" rel="nofollow noopener">Google Ads Settings</a>.
              </li>
              <li>
                You can also opt out of a third-party vendor's use of cookies for personalized advertising by visiting
                <a href="https://www.aboutads.info/" rel="nofollow noopener">aboutads.info</a>,
                <a href="https://www.youronlinechoices.eu/" rel="nofollow noopener">youronlinechoices.eu</a> (EU/UK), or
                <a href="https://youradchoices.ca/" rel="nofollow noopener">youradchoices.ca</a> (Canada).
              </li>
              <li>
                We do not have direct access to or control over the specific cookies used by third-party ad networks. Their
                data handling is governed by their own privacy policies. See
                <a href="https://policies.google.com/privacy" rel="nofollow noopener">Google's Privacy Policy</a>
                for detail on how Google processes data as an advertising partner.
              </li>
            </ul>
            <p>
              We do not sell your personal information for money. Where "sale" or "share" of personal information under US state
              privacy laws (such as the CCPA/CPRA) may include serving personalized advertisements, we honour valid opt-out
              signals such as Global Privacy Control (GPC) where technically possible.
            </p>
          </section>

          <section id="data-retention">
            <h2>7. Data Retention</h2>
            <p>
              We keep personal data only for as long as necessary to fulfill the purposes described in this policy,
              including legal, accounting, and security needs.
            </p>
            <ul>
              <li>Calculator inputs are generally not retained as user accounts are not required.</li>
              <li>Operational logs and diagnostics may be retained for limited periods for security and debugging.</li>
              <li>Support communications may be retained while an issue remains active and for audit continuity.</li>
            </ul>
          </section>

          <section id="data-sharing">
            <h2>8. Data Sharing and Processors</h2>
            <p>We do not sell personal information. We may share limited data with:</p>
            <ul>
              <li>Hosting providers and infrastructure partners that run our website.</li>
              <li>Security and performance monitoring vendors.</li>
              <li>Legal authorities where required by law or valid legal process.</li>
            </ul>
          </section>

          <section id="security">
            <h2>9. Security</h2>
            <p>
              We use reasonable administrative, technical, and organizational safeguards intended to protect information
              from unauthorized access, alteration, disclosure, or destruction.
            </p>
            <p>
              No internet transmission or storage system is guaranteed to be fully secure, so we encourage users to
              avoid submitting unnecessary sensitive data through public channels.
            </p>
          </section>

          <section id="your-rights">
            <h2>10. Your Privacy Rights</h2>
            <p>Depending on your location, you may have rights to:</p>
            <ul>
              <li>Request access to personal data we hold about you.</li>
              <li>Request correction, deletion, or restriction of your data.</li>
              <li>Object to certain processing or request portability where applicable.</li>
              <li>Withdraw consent where processing is based on consent.</li>
            </ul>
            <p>
              To exercise rights, contact us using the details in the Contact Us section below.
            </p>
          </section>

          <section id="us-privacy">
            <h2>11. US State Privacy Rights</h2>
            <p>
              If you are a resident of California, Virginia, Colorado, Connecticut, Utah, or another US state with a comprehensive
              consumer privacy law, you may have additional rights, including the right to:
            </p>
            <ul>
              <li>Know what personal information we collect about you.</li>
              <li>Delete personal information we hold about you, subject to certain exceptions.</li>
              <li>Correct inaccurate personal information.</li>
              <li>Opt out of the "sale" or "sharing" of personal information for cross-context behavioral advertising.</li>
              <li>Not receive discriminatory treatment for exercising these rights.</li>
            </ul>
            <p>
              To exercise these rights, contact us using the details in the Contact Us section below. We do not sell personal
              information for money. Where personalized advertising served by third parties may qualify as "sharing" under
              applicable law, we honour valid opt-out signals such as Global Privacy Control (GPC).
            </p>
          </section>

          <section id="children">
            <h2>12. Children&apos;s Privacy</h2>
            <p>
              Age Calculator Pro is not directed to children under 13, and we do not knowingly collect personal information
              from children under 13. If you believe a child has provided personal information to us, contact us and we will
              take appropriate steps to review and remove the data where required.
            </p>
          </section>

          <section id="international-transfers">
            <h2>13. International Transfers</h2>
            <p>
              If information is processed in countries other than your own, we take steps to ensure appropriate
              safeguards are in place, including contractual or technical protections when required.
            </p>
          </section>

          <section id="changes">
            <h2>14. Changes to This Policy</h2>
            <p>
              We may update this policy from time to time. Material updates will be reflected by revising the
              effective date at the top of this page.
            </p>
          </section>

          <section id="contact" class={`card ${styles.contactCard}`}>
            <h2>15. Contact Us</h2>
            <p>If you have privacy questions or requests, contact:</p>
            <div class={styles.contactGrid}>
              <p>Email: hashcode.dev@gmail.com</p>
              <p>Subject line: Age Calculator Pro Privacy Request</p>
              <p>Response target: within 30 days where legally required</p>
            </div>
          </section>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
