---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  keywords?: string;
  ogType?: 'website' | 'article';
  schemas?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  keywords = 'age calculator, date of birth calculator, age calculator by date of birth, days calculator, age difference calculator',
  ogType = 'website',
  schemas = [],
} = Astro.props;

const siteUrl = 'https://agecalculatorpro.app';
const ogImage = `${siteUrl}/og-logo.svg`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Age Calculator Pro" />
    <meta name="publisher" content="Age Calculator Pro" />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    <meta name="googlebot" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    <meta name="bingbot" content="index,follow" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="rating" content="general" />
    <meta name="language" content="English" />
    <meta http-equiv="content-language" content="en" />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Age Calculator Pro - Calculate Your Exact Age by Date of Birth" />
    <meta property="og:site_name" content="Age Calculator Pro" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@agecalculatorpro" />
    <meta name="twitter:creator" content="@agecalculatorpro" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Age Calculator Pro - Calculate Your Exact Age by Date of Birth" />

    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <script is:inline>
      (() => {
        const pref = localStorage.getItem('acp-theme') ?? 'system';
        const darkBySystem = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = pref === 'system' ? (darkBySystem ? 'dark' : 'light') : pref;
        document.documentElement.setAttribute('data-theme', resolved);
      })();
    </script>
  </head>
  <body>
    <slot />

    <div id="acp-cookie-banner" role="dialog" aria-live="polite" aria-labelledby="acp-cookie-banner-title" hidden>
      <div class="acp-cookie-banner__inner">
        <div class="acp-cookie-banner__text">
          <p id="acp-cookie-banner-title" class="acp-cookie-banner__title">We use cookies</p>
          <p class="acp-cookie-banner__body">
            This site uses essential storage to remember your theme, aggregated analytics to understand traffic, and may load
            third-party advertising cookies (including Google AdSense) to keep the calculator free. See our
            <a href="/cookie-policy">Cookie Policy</a> and <a href="/privacy-policy">Privacy Policy</a> for details.
          </p>
        </div>
        <div class="acp-cookie-banner__actions">
          <button type="button" class="acp-cookie-banner__btn acp-cookie-banner__btn--secondary" data-consent="decline">
            Decline non-essential
          </button>
          <button type="button" class="acp-cookie-banner__btn acp-cookie-banner__btn--primary" data-consent="accept">
            Accept all
          </button>
        </div>
      </div>
    </div>

    <style>
      #acp-cookie-banner {
        position: fixed;
        left: 16px;
        right: 16px;
        bottom: 16px;
        z-index: 100;
        background: var(--color-surface);
        color: var(--color-text);
        border: 1px solid var(--color-border);
        border-radius: 14px;
        box-shadow: 0 12px 40px rgba(2, 6, 23, 0.18);
        padding: 16px 18px;
      }

      .acp-cookie-banner__inner {
        display: flex;
        gap: 16px;
        align-items: center;
        justify-content: space-between;
        max-width: 1200px;
        margin: 0 auto;
        flex-wrap: wrap;
      }

      .acp-cookie-banner__text {
        flex: 1 1 320px;
        min-width: 260px;
      }

      .acp-cookie-banner__title {
        font-weight: 700;
        font-size: 14px;
        margin: 0 0 4px;
      }

      .acp-cookie-banner__body {
        font-size: 13px;
        color: var(--color-muted);
        line-height: 1.55;
        margin: 0;
      }

      .acp-cookie-banner__body a {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .acp-cookie-banner__actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .acp-cookie-banner__btn {
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid transparent;
      }

      .acp-cookie-banner__btn--primary {
        background: var(--gradient-primary);
        color: #fff;
      }

      .acp-cookie-banner__btn--secondary {
        background: var(--color-surface);
        color: var(--color-text);
        border-color: var(--color-border);
      }

      @media (max-width: 640px) {
        .acp-cookie-banner__actions {
          width: 100%;
          justify-content: flex-end;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const banner = document.getElementById('acp-cookie-banner');
        if (!banner) return;
        try {
          const stored = localStorage.getItem('acp-consent');
          if (!stored) {
            banner.hidden = false;
          }
        } catch (err) {
          banner.hidden = false;
        }
        banner.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const choice = target.getAttribute('data-consent');
          if (!choice) return;
          try {
            localStorage.setItem('acp-consent', choice);
          } catch (err) {
            /* storage may be blocked; hiding the banner without persistence is still fine */
          }
          banner.hidden = true;
        });
      })();
    </script>
  </body>
</html>
