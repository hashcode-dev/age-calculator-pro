---
import styles from '../styles/HomePage.module.css';
---

<header class={styles.headerWrap}>
  <div class={`container ${styles.header}`}>
    <a class={styles.brand} href="/" aria-label="Age Calculator Pro home">
      <img src="/favicon.svg" alt="Age Calculator Pro logo" width="28" height="28" />
      <span>Age Calculator Pro</span>
    </a>

    <nav class={styles.nav} aria-label="Main navigation">
      <a href="/">Home</a>
      <a href="/about-us">About Us</a>
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/terms-of-service">Terms of Service</a>
      <a href="/contact-us">Contact</a>
    </nav>
  </div>
</header>
